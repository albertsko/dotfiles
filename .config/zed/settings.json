// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // --- Profiles ---
  "profiles": {
    "agentic": {
      "settings": {
        "disable_ai": false,
        "toolbar": {
          "agent_review": true,
          "breadcrumbs": true,
          "code_actions": true,
          "quick_actions": true,
          "selections_menu": true
        }
      }
    },
  },
  // --- Languages ---
  "languages": {
    "Go": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
      "language_servers": ["gopls", "golangci-lint"],
    },
    "Go Mod": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "Shell Script": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["--filename", "{buffer_path}"],
        },
      },
    },
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "gofumpt": true,
      },
    },
  },
  // --- General ---
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Macchiato (Blur) [Heavy]"
  },
  "ui_font_family": "Inter",
  "ui_font_size": 15,
  "auto_update": true,
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  // --- Text Editor ---
  "cursor_shape": "bar",
  "cursor_blink": false,
  "buffer_font_family": "JetBrainsMonoNL Nerd Font",
  "buffer_font_size": 15,
  "buffer_line_height": "comfortable",
  "autosave": "on_focus_change",
  "format_on_save": "off",
  "inline_code_actions": false,
  "hard_tabs": false,
  "show_signature_help_after_edits": true,
  "extend_comment_on_newline": false,
  // --- Window Layout & Panels ---
  "outline_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "inlay_hints": {
    "enabled": false,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "agent_review": false,
    "code_actions": false,
    "selections_menu": false,
  },
  "tabs": {
    "activate_on_close": "neighbour",
    "close_position": "right",
    "git_status": true,
    "show_close_button": "hover",
    "show_diagnostics": "errors",
  },
  "project_panel": {
    "dock": "left",
    "entry_spacing": "comfortable",
    "default_width": 200,
    "indent_size": 12,
    "indent_guides": {
      "show": "never",
    },
  },
  "terminal": {
    "line_height": "standard",
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "minimap": {
    "show": "never",
  },
  "scrollbar": {
    "show": "never",
  },
  "gutter": {
    "line_numbers": true,
    "runnables": false,
    "breakpoints": false,
    "folds": false,
    "min_line_number_digits": 0,
  },
  // --- Tools ---
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
}
