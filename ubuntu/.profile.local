#!/usr/bin/env bash

export DOTFILES_PROFILE=ubuntu

# shellcheck disable=SC1090
. "$DOTFILES_HOME/$DOTFILES_PROFILE/.scripts/eval-brew.sh"

# load brew kegs to pkgconfig
if [[ -n "${HOMEBREW_PREFIX:-}" ]]; then
	BREW_KEGS_PKGCONFIG=(
		zlib
		libpq
		mysql-client
		openssl@3
	)

	for keg in "${BREW_KEGS_PKGCONFIG[@]}"; do
		pc_dir="$HOMEBREW_PREFIX/opt/$keg/lib/pkgconfig"
		[[ -d "$pc_dir" ]] && export PKG_CONFIG_PATH="$pc_dir${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}"
	done
fi
